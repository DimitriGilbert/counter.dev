WEBSTATS_COOKIE_SECRET=replace-with-a-long-random-secret
WEBSTATS_PASSWORD_SALT=replace-with-a-different-long-random-secret
WEBSTATS_ARCHIVE_MAX_AGE=24h

# Optional: set this to the public host(s) Dokploy routes to this app.
# Leave empty to allow any host when WEBSTATS_STATIC_ROOT is enabled.
# Example: WEBSTATS_ALLOWED_HOSTS=analytics.example.com,www.analytics.example.com
WEBSTATS_ALLOWED_HOSTS=

# Optional email integration secrets. Leave as dummy unless password recovery or feedback email is configured.
WEBSTATS_SMTP_SECRET=dummy
WEBSTATS_MAILGUN_SECRET_API_KEY=dummy
